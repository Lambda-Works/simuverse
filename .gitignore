# ============================================
# Secrets & credentials (never commit)
# ============================================
secrets/
secrets/*.json
**/*-firebase-adminsdk-*.json
.env
.env.local
.env.*
!env.example
!env.prod.example
!env.*.example
env
env.prod
env.firebase
env.openai
env.recaptcha

# ============================================
# Dependencies
# ============================================
node_modules
apps/*/node_modules
proxy/node_modules

# ============================================
# Build output
# ============================================
dist
apps/*/dist
proxy/dist
.next/
*.tsbuildinfo

# ============================================
# Logs
# ============================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Database backups & dumps (contain real data)
# ============================================
backups/
*.sql
*.session.sql

# Allow Prisma migrations (safe SQL, no data)
!apps/api-nest/prisma/migrations/**/*.sql

# ============================================
# Reference docs directory (old documentation, not source code)
# ============================================
md/

# ============================================
# Uploads (user files, could be sensitive)
# ============================================
apps/api-express/uploads/*
!apps/api-express/uploads/.gitkeep
apps/api-nest/uploads/*
!apps/api-nest/uploads/.gitkeep

# ============================================
# Legacy/abandoned code
# ============================================
supabaseold/

# ============================================
# Large binaries / documents (Keep in Drive, not git)
# ============================================
simuverse/
*.docx
*.pdf
*.csv
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.webp

# ============================================
# Backup/legacy files from refactors
# ============================================
.backup/

# ============================================
# Editor directories
# ============================================
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================
# AI agent configuration (local, not shared)
# ============================================
.atl/
.agents/

# Bug tracker (local, not shared)
BUGGS/

# Task tracker (local, not shared)
Cosas-que-hacer/

# SDD / OpenSpec (spec files not tracked in git)
# ============================================
openspec/

# ============================================
# OS files
# ============================================
Thumbs.db
Desktop.ini
docker-compose.override.yml

# ============================================
# Bug Tracking
# ============================================
bugs.md

# ============================================
# Prompts
# ============================================
prompts.md

# ============================================
# AI Handoff files (local only, not pushed)
# ============================================
HANDOFF-*.md
