# ── PostgreSQL ──
POSTGRES_USER=simuverse
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=simuverse
DATABASE_URL=postgresql://simuverse:your_postgres_password_here@localhost:5433/simuverse
DATABASE_URL_TEST=postgresql://simuverse:your_postgres_password_here@localhost:5433/simuverse_test

# ── Puertos ──
PUERTO_BACKEND=5000
PUERTO_BACKEND_INTERNAL=5002
PUERTO_FRONTEND=8080
PUERTO_POSTGRES=5433

# ── Auth ──
JWT_SECRET=your_jwt_secret_here

# ── Firebase Auth (use separate projects for dev vs prod) ──
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Frontend (NEXT_PUBLIC_*): set per environment (.env.local vs deploy secrets)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# ── reCAPTCHA v2 ──
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# Optional: force JWT auth fallback (tests only)
# AUTH_TEST_MODE=jwt

# Public site URL (SEO sitemap/robots)
NEXT_PUBLIC_SITE_URL=http://localhost:8080


# ── Next.js ──
NEXT_PUBLIC_API_URL=http://localhost:${PUERTO_BACKEND:-5000}/api

# ── Gemini API ──
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=2000
GEMINI_TEMPERATURE=0.7

# ── DeepSeek API (tech-sheet pipeline + chat fallback) ──
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash

# ── OpenAI API (chat simulation primary) ──
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-5.4-nano

# ── Certificate Configuration ──
CERTIFICATE_ISSUER_NAME=SimuVerse Academy
CERTIFICATE_ISSUER_ADDRESS=Madrid, España
CERTIFICATE_ISSUER_WEBSITE=www.simuverse.com
CERTIFICATE_THEME=professional

# ── PWA Configuration ──
PWA_ENABLED=true
CACHE_VERSION=v1
MAX_CACHE_SIZE=500
INDEXEDDB_NAME=SimuVerseDB

# ── Security ──
ASSESSMENT_HMAC_SECRET=your_hmac_secret_here
CORS_ORIGIN=http://localhost:3000

# ── Logging & Monitoring ──
DEBUG_LOG=false
TRACK_TOKENS=true
TRACK_ACTIONS=true

# ── Environment ──
NODE_ENV=development