# ── PostgreSQL ──
POSTGRES_USER=simuverse
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=simuverse
DATABASE_URL=postgresql://simuverse:your_postgres_password_here@localhost:5433/simuverse
DATABASE_URL_TEST=postgresql://simuverse:your_postgres_password_here@localhost:5433/simuverse_test

# ── Puertos ──
PUERTO_BACKEND=5000
PUERTO_BACKEND_INTERNAL=5002
PUERTO_FRONTEND=8080
PUERTO_POSTGRES=5433

# ── Auth ──
JWT_SECRET=your_jwt_secret_here

# ── Firebase Auth — backend (service account; copiar del JSON descargado en paso 5) ──
# Leave empty for local/CI without Firebase; JWT fallback is used until set.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# Or point to a downloaded service-account JSON:
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── Firebase Auth — frontend (web app config, paso 4) ──
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAOi0miUMUuqjnJ-guK7Q6izLP44Xg9hrY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=simuverse-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=simuverse-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=simuverse-dev.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=353860824966
NEXT_PUBLIC_FIREBASE_APP_ID=1:353860824966:web:0e6de6defaddc338034607

# ── reCAPTCHA v2 ──
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# Optional: force JWT auth fallback (tests only)
# AUTH_TEST_MODE=jwt

# Public site URL (SEO sitemap/robots)
NEXT_PUBLIC_SITE_URL=http://localhost:8080


# ── Next.js ──
NEXT_PUBLIC_API_URL=http://localhost:${PUERTO_BACKEND:-5000}/api

# ── DeepSeek API (tech-sheet pipeline + chat fallback) ──
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash

# ── OpenAI API (chat simulation primary) ──
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Certificate Configuration ──
CERTIFICATE_ISSUER_NAME=SimuVerse Academy
CERTIFICATE_ISSUER_ADDRESS=Madrid, España
CERTIFICATE_ISSUER_WEBSITE=www.simuverse.com
CERTIFICATE_THEME=professional

# ── PWA Configuration ──
PWA_ENABLED=true
CACHE_VERSION=v1
MAX_CACHE_SIZE=500
INDEXEDDB_NAME=SimuVerseDB

# ── Security ──
ASSESSMENT_HMAC_SECRET=your_hmac_secret_here
CORS_ORIGIN=http://localhost:3000

# ── Logging & Monitoring ──
DEBUG_LOG=false
TRACK_TOKENS=true
TRACK_ACTIONS=true

# ── Environment ──
NODE_ENV=development