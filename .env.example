# ============================================
# Frontend (Next.js) — Environment Variables
# Copy to .env.local and fill in your values
# ============================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:5000/api

NEXT_PUBLIC_APP_NAME=SimuVerse
NEXT_PUBLIC_APP_VERSION=2.0.0

# LLM Configuration (Gemini API)
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
NEXT_PUBLIC_GEMINI_MODEL=gemini-1.5-flash
NEXT_PUBLIC_GEMINI_MAX_TOKENS=2000
NEXT_PUBLIC_GEMINI_TEMPERATURE=0.7

# Certificate Configuration
NEXT_PUBLIC_CERTIFICATE_ISSUER_NAME=SimuVerse Academy
NEXT_PUBLIC_CERTIFICATE_ISSUER_ADDRESS=Madrid, España
NEXT_PUBLIC_CERTIFICATE_ISSUER_WEBSITE=www.simuverse.com
NEXT_PUBLIC_CERTIFICATE_THEME=professional

# PWA Configuration
NEXT_PUBLIC_PWA_ENABLED=true
NEXT_PUBLIC_CACHE_VERSION=v1
NEXT_PUBLIC_MAX_CACHE_SIZE=500
NEXT_PUBLIC_INDEXEDDB_NAME=SimuVerseDB

# Logging & Monitoring
NEXT_PUBLIC_DEBUG_LOG=false
NEXT_PUBLIC_TRACK_TOKENS=true
NEXT_PUBLIC_TRACK_ACTIONS=true

# Environment
NEXT_PUBLIC_ENV=development

# ============================================
# Backend (Express) — Environment Variables
# Copy to .env and fill in your values
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MySQL via TypeORM)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_DATABASE=simuverse

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ============================================
# Proxy — Environment Variables
# ============================================

# Proxy port (single API entrypoint)
PROXY_PORT=5000
