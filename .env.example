# ── MySQL ──
MYSQL_ROOT_PASSWORD=SimuVerseRoot2024secret
MYSQL_DATABASE=simuverse
MYSQL_USER=simuverse
MYSQL_PASSWORD=SimuVerse2024secret

# ── Puertos ──
PUERTO_MYSQL=3309
PUERTO_PROXY=5000
PUERTO_BACKEND=5001
PUERTO_BACKEND_NEST=5002
PUERTO_FRONTEND=8080

# ── Express API ──
JWT_SECRET=cambiar-por-secret-seguro

# ── Next.js ──
NEXT_PUBLIC_API_URL=http://localhost:${PUERTO_PROXY:-5000}/api

# ── Gemini API ──
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=2000
GEMINI_TEMPERATURE=0.7

# ── Certificate Configuration ──
CERTIFICATE_ISSUER_NAME=SimuVerse Academy
CERTIFICATE_ISSUER_ADDRESS=Madrid, España
CERTIFICATE_ISSUER_WEBSITE=www.simuverse.com
CERTIFICATE_THEME=professional

# ── PWA Configuration ──
PWA_ENABLED=true
CACHE_VERSION=v1
MAX_CACHE_SIZE=500
INDEXEDDB_NAME=SimuVerseDB

# ── Logging & Monitoring ──
DEBUG_LOG=false
TRACK_TOKENS=true
TRACK_ACTIONS=true

# ── Environment ──
NODE_ENV=development