# ============================================
# FASE 3 - LLM, CERTIFICATES & PWA CONFIGURATION
# ============================================

# ============================================
# LLM CONFIGURATION (Gemini API)
# ============================================
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-1.5-flash
VITE_GEMINI_MAX_TOKENS=2000
VITE_GEMINI_TEMPERATURE=0.7

# Alternative: OpenAI configuration (optional)
# VITE_OPENAI_API_KEY=your_openai_api_key_here
# VITE_OPENAI_MODEL=gpt-4-turbo-preview

# ============================================
# CERTIFICATE CONFIGURATION
# ============================================
# Issuer information (shown on certificates)
VITE_CERTIFICATE_ISSUER_NAME=SimuVerse Academy
VITE_CERTIFICATE_ISSUER_ADDRESS=Madrid, España
VITE_CERTIFICATE_ISSUER_WEBSITE=www.simuverse.com
VITE_CERTIFICATE_ISSUER_LOGO_URL=https://your-domain.com/logo.png

# Certificate theme (professional | modern | light | dark)
VITE_CERTIFICATE_THEME=professional

# Email configuration for certificate sending
VITE_CERTIFICATE_EMAIL_SERVICE=gmail
VITE_CERTIFICATE_EMAIL_USER=your-email@gmail.com
VITE_CERTIFICATE_EMAIL_PASSWORD=your-app-password
VITE_CERTIFICATE_EMAIL_FROM=noreply@simuverse.com

# ============================================
# PWA CONFIGURATION
# ============================================
# Enable/disable offline support
VITE_PWA_ENABLED=true

# Cache version (increment to force cache refresh)
VITE_CACHE_VERSION=v1

# Maximum items to cache
VITE_MAX_CACHE_SIZE=500

# IndexedDB database name
VITE_INDEXEDDB_NAME=SimuVerseDB

# ============================================
# API CONFIGURATION
# ============================================
# Backend API URL
VITE_API_URL=http://localhost:5001/api

# Supabase configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_KEY=your_supabase_key_here

# ============================================
# LOGGING & MONITORING
# ============================================
# Enable debug logging
VITE_DEBUG_LOG=false

# Track token usage for LLM
VITE_TRACK_TOKENS=true

# Track all user actions
VITE_TRACK_ACTIONS=true

# ============================================
# ENVIRONMENT
# ============================================
VITE_ENV=development
# Options: development | staging | production
