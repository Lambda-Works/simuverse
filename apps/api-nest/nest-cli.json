{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": false,
    "assets": ["**/*.md"],
    "watchOptions": {
      "excludeDirectories": ["node_modules", "dist", "test", "prisma", ".git"],
      "excludeFiles": ["*.log", "*.sql"]
    }
  }
}
