NEXT_PUBLIC_API_URL=http://localhost:5001/api
NEXT_PUBLIC_APP_NAME=MSM - Motor de Simulación Modular
NEXT_PUBLIC_APP_VERSION=2.0.0
# ============================================
# PHASE 3 - LLM CONFIGURATION (Gemini API)
# ============================================
NEXT_PUBLIC_GEMINI_API_KEY=AIzaSyDemoKeyForDevelopment
NEXT_PUBLIC_GEMINI_MODEL=gemini-1.5-flash
NEXT_PUBLIC_GEMINI_MAX_TOKENS=2000
NEXT_PUBLIC_GEMINI_TEMPERATURE=0.7

# ============================================
# PHASE 3 - CERTIFICATE CONFIGURATION
# ============================================
NEXT_PUBLIC_CERTIFICATE_ISSUER_NAME=SimuVerse Academy
NEXT_PUBLIC_CERTIFICATE_ISSUER_ADDRESS=Madrid, España
NEXT_PUBLIC_CERTIFICATE_ISSUER_WEBSITE=www.simuverse.com
NEXT_PUBLIC_CERTIFICATE_THEME=professional

# ============================================
# PHASE 3 - PWA CONFIGURATION
# ============================================
NEXT_PUBLIC_PWA_ENABLED=true
NEXT_PUBLIC_CACHE_VERSION=v1
NEXT_PUBLIC_MAX_CACHE_SIZE=500
NEXT_PUBLIC_INDEXEDDB_NAME=SimuVerseDB

# ============================================
# PHASE 3 - LOGGING & MONITORING
# ============================================
NEXT_PUBLIC_DEBUG_LOG=false
NEXT_PUBLIC_TRACK_TOKENS=true
NEXT_PUBLIC_TRACK_ACTIONS=true

# ============================================
# ENVIRONMENT
# ============================================
NEXT_PUBLIC_ENV=development