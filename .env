VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=MSM - Motor de Simulación Modular
VITE_APP_VERSION=2.0.0
# ============================================
# PHASE 3 - LLM CONFIGURATION (Gemini API)
# ============================================
VITE_GEMINI_API_KEY=AIzaSyDemoKeyForDevelopment
VITE_GEMINI_MODEL=gemini-1.5-flash
VITE_GEMINI_MAX_TOKENS=2000
VITE_GEMINI_TEMPERATURE=0.7

# ============================================
# PHASE 3 - CERTIFICATE CONFIGURATION
# ============================================
VITE_CERTIFICATE_ISSUER_NAME=SimuVerse Academy
VITE_CERTIFICATE_ISSUER_ADDRESS=Madrid, España
VITE_CERTIFICATE_ISSUER_WEBSITE=www.simuverse.com
VITE_CERTIFICATE_THEME=professional

# ============================================
# PHASE 3 - PWA CONFIGURATION
# ============================================
VITE_PWA_ENABLED=true
VITE_CACHE_VERSION=v1
VITE_MAX_CACHE_SIZE=500
VITE_INDEXEDDB_NAME=SimuVerseDB

# ============================================
# PHASE 3 - LOGGING & MONITORING
# ============================================
VITE_DEBUG_LOG=false
VITE_TRACK_TOKENS=true
VITE_TRACK_ACTIONS=true

# ============================================
# ENVIRONMENT
# ============================================
VITE_ENV=development