{
  "name": "simuverse",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "start": "npm run start -w apps/web",
    "lint": "npm run lint -w apps/web",
    "test": "npm run test -w apps/web",
    "test:watch": "npm run test:watch -w apps/web",
    "cypress:open": "npm run cypress:open -w apps/web",
    "cypress:e2e": "npm run cypress:e2e -w apps/web",
    "dev:api": "npm run dev -w apps/api-express",
    "build:api": "npm run build -w apps/api-express",
    "start:api": "npm run start -w apps/api-express"
  }
}
